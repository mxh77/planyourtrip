# URL de l'API backend
# Sur émulateur : http://localhost:3111
# Sur téléphone physique : http://192.168.X.X:3111 (ton IP locale)
EXPO_PUBLIC_API_URL=http://localhost:3111

# Clé API Google Maps (Android) — obligatoire pour react-native-maps
# Crée une clé sur https://console.cloud.google.com/ (Maps SDK for Android)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSy...
