# Supabase PostgreSQL — pooled connection (for Prisma queries)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — direct connection (for Prisma migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# Google Maps API — Private key for Routes API (backend only, never expose in frontend)
GOOGLE_MAPS_API_KEY="your-google-maps-server-api-key"

# PowerSync Cloud
POWERSYNC_URL="https://YOUR_INSTANCE.powersync.journeyapps.com"
POWERSYNC_JWT_SECRET="your-powersync-hs256-secret"
POWERSYNC_JWT_KID="your-key-id-uuid"

# OpenAI (optionnel — pour l'analyse IA des équipements ✨)
OPENAI_API_KEY=sk-...

# DeepSeek (optionnel)
DEEPSEEK_API_KEY=sk-...

# Tavily Search API (optionnel — pour trouver plus de pages web dans ✨)
# Gratuit : 1000 requêtes/mois sans CB — inscription : https://app.tavily.com/
TAVILY_API_KEY="tvly-votre-clé-ici"

# Server port
PORT=3111
